    "cgu": {
      "article1": { "title": "Artikel 1 – Syfte", "content": "Dessa villkor reglerar användningen av CasaFix-appen, en plattform för hemtjänster på Costa del Sol." },
      "article2": { "title": "Artikel 2 – Åtkomst", "content": "Åtkomst till appen är gratis. Vissa tjänster kräver ett konto." },
      "article3": { "title": "Artikel 3 – Tjänster", "content": "CasaFix förmedlar hantverkare för VVS, el, lås, värme, AC, skadedjur, vitvaror, glas, småjobb, renovering, pool och trädgård. Priserna är vägledande." },
      "article4": { "title": "Artikel 4 – Priser & Betalning", "content": "Priserna är vägledande inkl. moms. Inget påslag för kvällar, helger eller helgdagar. Betalning sker uteslutande online: vid bokning förauktoriseras maxbeloppet på kundens kort. Efter arbetet anger hantverkaren det verkliga priset och endast detta debiteras." },
      "article5": { "title": "Artikel 5 – Garantier", "content": "Alla arbeten har 1 års garanti. Kostnadsfritt återbesök inom 48 timmar vid problem." },
      "article6": { "title": "Artikel 6 – Ansvar", "content": "CasaFix agerar som förmedlare och väljer kvalificerade och försäkrade fackfolk." },
      "article7": { "title": "Artikel 7 – Personuppgifter", "content": "CasaFix följer GDPR och spansk LOPD. Data används enbart för tjänsten." },
