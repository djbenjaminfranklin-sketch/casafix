  "legal": {
    "cguTitle": "Allgemeine Nutzungsbedingungen",
    "legalNoticeTitle": "Impressum",
    "privacyTitle": "Datenschutzerklärung",
    "lastUpdated": "Letzte Aktualisierung",
    "cgu": {
      "article1": {
        "title": "Artikel 1 – Zweck",
        "content": "Diese AGB regeln die Nutzung der CasaFix-App, einer Plattform zur Vermittlung von Haushaltsdienstleistungen in Frankreich."
      },
      "article2": {
        "title": "Artikel 2 – Zugang",
        "content": "Der Zugang zur App ist kostenlos. Einige Dienste erfordern die Erstellung eines Benutzerkontos. Der Nutzer verpflichtet sich, korrekte Daten anzugeben."
      },
      "article3": {
        "title": "Artikel 3 – Dienstleistungen",
        "content": "CasaFix vermittelt Handwerker für: Klempner, Elektriker, Schlüsseldienst, Heizung, Klima, Schädlingsbekämpfung, Haushaltsgeräte, Glaserei, kleine Reparaturen, Renovierung, Pool und Garten. Die angezeigten Preise sind Richtwerte. Ein kostenloser, unverbindlicher Kostenvoranschlag wird vor jeder Arbeit erstellt."
      },
      "article4": {
        "title": "Artikel 4 – Preise & Zahlung",
        "content": "Die angezeigten Preise sind Richtwerte inkl. MwSt. Kein Aufpreis für Abend, Wochenende oder Feiertage. Die Zahlung erfolgt ausschließlich online: Bei der Buchung wird der Höchstbetrag auf Ihrer Karte vorautorisiert. Nach der Arbeit gibt der Handwerker den endgültigen Preis ein und nur dieser wird abgebucht. Die Rechnung wird innerhalb von 48 Stunden per E-Mail versandt."
      },
      "article5": {
        "title": "Artikel 5 – Garantien",
        "content": "Alle Arbeiten haben 1 Jahr Garantie auf Teile und Arbeit. Bei Problemen wird innerhalb von 48 Stunden ein kostenloser Rückbesuch organisiert."
      },
      "article6": {
        "title": "Artikel 6 – Haftung",
        "content": "CasaFix handelt als Vermittler und wählt qualifizierte und versicherte Fachleute aus."
      },
      "article7": {
        "title": "Artikel 7 – Datenschutz",
        "content": "CasaFix hält die DSGVO und das französische Datenschutzgesetz (Loi Informatique et Libertés) ein. Daten auf EU-Servern (Supabase)."
      },
      "article8": {
        "title": "Artikel 8 – Geistiges Eigentum",
        "content": "Alle App-Inhalte sind urheberrechtlich geschützt. Vervielfältigung ohne Genehmigung ist verboten."
      },
      "article9": {
        "title": "Artikel 9 – Geltendes Recht",
        "content": "Diese AGB unterliegen französischem Recht. Gerichtsstand sind die zuständigen französischen Gerichte."
      },
      "article10": {
        "title": "Artikel 10 – Änderungen",
        "content": "CasaFix behält sich das Recht vor, diese AGB jederzeit zu ändern. Die weitere Nutzung gilt als Zustimmung."
      }
    },
