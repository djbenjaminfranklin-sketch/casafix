  "legal": {
    "cguTitle": "Algemene Gebruiksvoorwaarden",
    "legalNoticeTitle": "Juridische informatie",
    "privacyTitle": "Privacybeleid",
    "lastUpdated": "Laatst bijgewerkt",
    "cgu": {
      "article1": {
        "title": "Artikel 1 – Doel",
        "content": "Deze Algemene Gebruiksvoorwaarden (hierna «AGV») hebben tot doel de voorwaarden en modaliteiten van het gebruik van de mobiele applicatie CasaFix (hierna «de Applicatie») te definiëren, evenals de rechten en verplichtingen van de partijen. De Applicatie is een bemiddelingsdienst tussen particulieren die thuisdiensten zoeken en gekwalificeerde vakmensen die actief zijn in Frankrijk."
      },
      "article2": {
        "title": "Artikel 2 – Toegang tot de Applicatie",
        "content": "De toegang tot de Applicatie is gratis. Voor het gebruik van bepaalde diensten kan het aanmaken van een gebruikersaccount vereist zijn. De gebruiker verbindt zich ertoe waarheidsgetrouwe en actuele informatie te verstrekken en de vertrouwelijkheid van zijn inloggegevens te bewaren."
      },
      "article3": {
        "title": "Artikel 3 – Aangeboden diensten",
        "content": "CasaFix biedt bemiddeling tussen gebruikers en vakmensen voor: loodgieterwerk, elektriciteit, slotenmakerij, verwarming, airconditioning, ongediertebestrijding, huishoudapparaten, glaswerk, kleine klussen, renovatie, zwembad en tuinonderhoud. De getoonde prijzen zijn indicatief. Voorafgaand aan elke interventie wordt een gratis en vrijblijvende offerte opgesteld."
      },
      "article4": {
        "title": "Artikel 4 – Tarieven en betaling",
        "content": "De getoonde prijzen zijn indicatief en inclusief btw. Er wordt geen toeslag berekend voor avond-, weekend- of feestdaginterventies. De betaling vindt uitsluitend online plaats: bij het boeken wordt het maximumbedrag vooraf geautoriseerd op de kaart van de klant. Na afloop van de interventie geeft de vakman de definitieve prijs aan en alleen dit bedrag wordt afgeschreven. Het verschil wordt automatisch vrijgegeven. De factuur wordt binnen 48 uur per e-mail verzonden."
      },
      "article5": {
        "title": "Artikel 5 – Garanties",
        "content": "Alle interventies worden gedekt door een garantie van 1 jaar op onderdelen en arbeid. Bij een incident wordt binnen 48 uur een gratis herbezoek georganiseerd. De vakmensen beschikken over een beroepsaansprakelijkheidsverzekering."
      },
      "article6": {
        "title": "Artikel 6 – Aansprakelijkheid",
        "content": "CasaFix treedt op als bemiddelaar en is niet rechtstreeks aansprakelijk voor de kwaliteit van de dienstverlening, maar verbindt zich ertoe gekwalificeerde en verzekerde vakmensen te selecteren."
      },
      "article7": {
        "title": "Artikel 7 – Persoonsgegevens",
        "content": "CasaFix voldoet aan de AVG en de Franse Loi Informatique et Libertes. De verzamelde gegevens worden uitsluitend gebruikt voor de werking van de dienst en worden niet zonder toestemming aan derden verstrekt."
      },
      "article8": {
        "title": "Artikel 8 – Intellectueel eigendom",
        "content": "Alle elementen van de Applicatie zijn beschermd door de wetten op het intellectueel eigendom. Reproductie zonder toestemming is verboden."
      },
      "article9": {
        "title": "Artikel 9 – Toepasselijk recht",
        "content": "Deze AGV worden beheerst door het Frans recht. Geschillen worden voorgelegd aan de bevoegde Franse rechtbanken."
      },
      "article10": {
        "title": "Artikel 10 – Wijzigingen",
        "content": "CasaFix behoudt zich het recht voor de AGV op elk moment te wijzigen. Voortgezet gebruik van de Applicatie houdt aanvaarding van de nieuwe voorwaarden in."
      }
    },
